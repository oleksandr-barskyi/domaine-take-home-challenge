{% comment %}
  Product page focused on the reusable Domaine product card component.
{% endcomment %}

<section class="domaine-scope bg-white px-5 py-12 sm:px-8 lg:px-12">
  <div class="mx-auto mb-8 max-w-7xl">
    <a
      class="inline-flex items-center justify-center rounded-full border border-[#0a4874] px-5 py-2 text-sm font-medium leading-none tracking-normal text-[#0a4874] transition hover:bg-[#0a4874] hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2"
      href="{{ routes.root_url }}"
    >
      Back
    </a>
  </div>

  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[620px_minmax(0,1fr)] lg:items-start">
    {% render 'domaine-product-card', product: product %}
    {% render 'domaine-product-variant-grid', product: product %}
  </div>

  {% if product.description != blank %}
    <div class="mx-auto mt-12 max-w-7xl border-t border-[#e8e8e8] pt-8">
      <div class="max-w-[620px] text-sm leading-relaxed text-zinc-700">
        {{ product.description }}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
