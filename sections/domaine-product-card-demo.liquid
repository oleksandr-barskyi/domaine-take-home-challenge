{% liquid
  assign demo_product = section.settings.product
  if demo_product == blank
    assign demo_product = all_products['classic-cotton-tee']
  endif
  assign secondary_demo_product = section.settings.secondary_product
  if secondary_demo_product == blank
    assign secondary_demo_product = all_products['second-generic-product']
  endif
%}

<section class="domaine-scope bg-white px-5 py-12 sm:px-8 lg:px-12">
  <div class="mx-auto grid max-w-7xl gap-12">
    <div class="grid gap-10 lg:grid-cols-[620px_minmax(0,1fr)] lg:items-start">
    {% if demo_product != blank %}
      {% render 'domaine-product-card', product: demo_product %}

      {% render 'domaine-product-variant-grid', product: demo_product %}
    {% else %}
      <div class="mx-auto max-w-[360px] rounded-lg border border-dashed border-zinc-300 p-6 text-sm text-zinc-600">
        Select a product in the theme editor or create a product with handle <strong>classic-cotton-tee</strong>.
      </div>
    {% endif %}
    </div>

    <div class="mt-16 border-t-2 border-[#0a4874]">
      <div class="flex max-w-[760px] flex-col gap-6 pt-[100px] sm:flex-row sm:items-center sm:justify-between sm:gap-12">
        <p class="text-sm font-medium leading-snug tracking-normal text-[#111111]">
          Second generic product to ensure the component reusability.
        </p>

        {% if secondary_demo_product != blank %}
          <a
            class="inline-flex w-fit items-center justify-center rounded-full border border-[#0a4874] px-5 py-2 text-sm font-medium leading-none tracking-normal text-[#0a4874] transition hover:bg-[#0a4874] hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2"
            href="{{ secondary_demo_product.url }}"
          >
            View generic product
          </a>
        {% else %}
          <span class="text-sm leading-snug text-zinc-600">
            Create a product with handle <strong>second-generic-product</strong> or select a secondary product in the theme editor.
          </span>
        {% endif %}
      </div>
      <div class="mt-[100px] border-t-2 border-[#0a4874]"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Domaine product card demo",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "product",
      "id": "secondary_product",
      "label": "Secondary product"
    }
  ],
  "presets": [
    {
      "name": "Domaine product card demo",
      "category": "Products"
    }
  ]
}
{% endschema %}
