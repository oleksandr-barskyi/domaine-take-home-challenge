{% liquid
  assign demo_product = section.settings.product
  if demo_product == blank
    assign demo_product = all_products['classic-cotton-tee']
  endif
  assign color_option_index = nil
  assign color_option = nil

  for option in demo_product.options_with_values
    assign option_name = option.name | downcase
    if option_name contains 'color' or option_name contains 'colour'
      assign color_option_index = forloop.index0
      assign color_option = option
      break
    endif
  endfor
%}

<section class="domaine-scope bg-white px-5 py-12 sm:px-8 lg:px-12">
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[620px_minmax(0,1fr)] lg:items-start">
    {% if demo_product != blank %}
      {% render 'domaine-product-card', product: demo_product %}

      {% if demo_product.variants.size > 1 %}
        <div class="min-w-0">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-normal text-zinc-500">
            Available variants
          </h2>

          <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3" role="list">
            {% for variant in demo_product.variants %}
              {% liquid
                assign variant_asset_position = forloop.index
                assign variant_media = variant.featured_media
                assign variant_image = variant_media.preview_image
                assign variant_secondary_image = nil
                assign variant_color = ''

                if color_option_index != nil
                  assign variant_color = variant.options[color_option_index] | downcase
                  assign variant_color_key = variant_color | replace: ' ', '_'
                endif

                if variant_image == nil and variant_color != blank
                  for media in demo_product.media
                    assign media_alt = media.alt | downcase
                    assign media_alt_key = media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and media_alt_key contains variant_color_key
                      unless media_alt contains 'model' or media_alt contains 'man' or media_alt contains 'men' or media_alt contains 'worn'
                        assign variant_media = media
                        assign variant_image = media.preview_image
                        break
                      endunless
                    endif
                  endfor
                endif

                if variant_image == nil and variant_color != blank
                  for media in demo_product.media
                    assign media_alt = media.alt | downcase
                    assign media_alt_key = media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and media_alt_key contains variant_color_key
                      assign variant_media = media
                      assign variant_image = media.preview_image
                      break
                    endif
                  endfor
                endif

                for media in demo_product.media
                  assign media_alt = media.alt | downcase
                  assign media_alt_key = media_alt | replace: ' ', '_'
                  if media.media_type == 'image' and variant_color != blank and media_alt_key contains variant_color_key
                    if variant_media == nil or media.id != variant_media.id
                      if media_alt contains 'model' or media_alt contains 'man' or media_alt contains 'men' or media_alt contains 'worn'
                        assign variant_secondary_image = media.preview_image
                        break
                      endif
                    endif
                  endif
                endfor

                if variant_secondary_image == nil
                  for media in demo_product.media
                    assign media_alt = media.alt | downcase
                    assign media_alt_key = media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and variant_color != blank and media_alt_key contains variant_color_key
                      if variant_media == nil or media.id != variant_media.id
                        assign variant_secondary_image = media.preview_image
                        break
                      endif
                    endif
                  endfor
                endif

                if variant_secondary_image == nil and color_option != nil
                  assign image_position = 0
                  assign model_position = variant_asset_position | plus: color_option.values.size
                  for media in demo_product.media
                    if media.media_type == 'image'
                      assign image_position = image_position | plus: 1
                    endif
                    if media.media_type == 'image' and image_position == model_position
                      assign variant_secondary_image = media.preview_image
                      break
                    endif
                  endfor
                endif

                assign variant_on_sale = false
                if variant.compare_at_price > variant.price
                  assign variant_on_sale = true
                endif
              %}

              <li class="rounded-lg border border-zinc-200 bg-white p-3">
                <div class="grid aspect-square grid-cols-[0.9fr_1.1fr] items-end gap-2 overflow-hidden bg-white">
                  {% if variant_image %}
                    <img
                      class="h-full max-h-[78%] w-full self-center object-contain"
                      src="{{ variant_image | image_url: width: 360 }}"
                      alt="{{ variant_image.alt | default: variant.title | escape }}"
                      width="360"
                      height="360"
                      loading="lazy"
                    >
                  {% endif %}

                  {% if variant_secondary_image %}
                    <img
                      class="h-full w-full object-contain"
                      src="{{ variant_secondary_image | image_url: width: 360 }}"
                      alt="{{ variant_secondary_image.alt | default: variant.title | escape }}"
                      width="360"
                      height="360"
                      loading="lazy"
                    >
                  {% endif %}
                </div>

                <div class="mt-3 grid gap-1">
                  <p class="text-sm font-medium leading-snug text-zinc-950">
                    {{ variant.title | escape }}
                  </p>
                  <p class="flex flex-wrap items-baseline gap-2 text-sm">
                    {% if variant_on_sale %}
                      <s class="text-zinc-500">{{ variant.compare_at_price | money }}</s>
                    {% endif %}
                    <span class="{% if variant_on_sale %}text-[#ff0000]{% else %}text-zinc-950{% endif %}">
                      {{ variant.price | money }}
                    </span>
                  </p>
                </div>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% else %}
      <div class="mx-auto max-w-[360px] rounded-lg border border-dashed border-zinc-300 p-6 text-sm text-zinc-600">
        Select a product in the theme editor or create a product with handle <strong>classic-cotton-tee</strong>.
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Domaine product card demo",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    }
  ],
  "presets": [
    {
      "name": "Domaine product card demo",
      "category": "Products"
    }
  ]
}
{% endschema %}
