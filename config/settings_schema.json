[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "Domaine product card",
    "settings": [
      {
        "type": "header",
        "content": "Typography"
      },
      {
        "type": "font_picker",
        "id": "domaine_card_text_font",
        "default": "roboto_n4",
        "label": "Text font"
      },
      {
        "type": "font_picker",
        "id": "domaine_card_badge_font",
        "default": "roboto_n4",
        "label": "Sale badge font"
      },
      {
        "type": "select",
        "id": "domaine_card_title_weight",
        "default": "600",
        "label": "Product title weight",
        "options": [
          {
            "value": "500",
            "label": "Medium"
          },
          {
            "value": "600",
            "label": "Semibold"
          },
          {
            "value": "700",
            "label": "Bold"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": "The sale badge tries Franklin Gothic first when it is available, then uses this selected font."
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color",
        "id": "domaine_card_text_color",
        "default": "#111111",
        "label": "Text"
      },
      {
        "type": "color",
        "id": "domaine_card_title_color",
        "default": "#0A4874",
        "label": "Product title"
      },
      {
        "type": "color",
        "id": "domaine_card_sale_color",
        "default": "#FF0000",
        "label": "Sale"
      },
      {
        "type": "color",
        "id": "domaine_card_border_color",
        "default": "#E8E8E8",
        "label": "Media border"
      },
      {
        "type": "color",
        "id": "domaine_card_active_color",
        "default": "#0A4874",
        "label": "Active state"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  }
]
