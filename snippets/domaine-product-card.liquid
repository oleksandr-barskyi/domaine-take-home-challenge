{% comment %}
  Reusable Domaine product card.
  Accepts:
  - product: Shopify product object
{% endcomment %}

{% liquid
  assign card_product = product
  assign selected_variant = card_product.selected_or_first_available_variant
  assign color_option_index = nil
  assign color_option = nil

  for option in card_product.options_with_values
    assign option_name = option.name | downcase
    if option_name contains 'color' or option_name contains 'colour'
      assign color_option_index = forloop.index0
      assign color_option = option
      break
    endif
  endfor

  assign selected_color = ''
  assign selected_color_position = 0

  if color_option_index != nil
    assign selected_color = selected_variant.options[color_option_index] | downcase
    assign selected_color_key = selected_color | replace: ' ', '_'
    for color_value in color_option.values
      assign color_value_downcase = color_value | downcase
      if color_value_downcase == selected_color
        assign selected_color_position = forloop.index
        break
      endif
    endfor
  endif

  assign primary_media = selected_variant.featured_media
  assign primary_image = primary_media.preview_image
  assign secondary_image = nil

  if primary_image == nil and selected_color != blank
    for media in card_product.media
      assign media_alt = media.alt | downcase
      assign media_alt_key = media_alt | replace: ' ', '_'
      if media.media_type == 'image' and media_alt_key contains selected_color_key
        unless media_alt contains 'model' or media_alt contains 'man' or media_alt contains 'men' or media_alt contains 'worn'
          assign primary_media = media
          assign primary_image = media.preview_image
          break
        endunless
      endif
    endfor
  endif

  if primary_image == nil and selected_color != blank
    for media in card_product.media
      assign media_alt = media.alt | downcase
      assign media_alt_key = media_alt | replace: ' ', '_'
      if media.media_type == 'image' and media_alt_key contains selected_color_key
        assign primary_media = media
        assign primary_image = media.preview_image
        break
      endif
    endfor
  endif

  if card_product.media.size > 1
    for media in card_product.media
      assign media_alt = media.alt | downcase
      assign media_alt_key = media_alt | replace: ' ', '_'
      if media.media_type == 'image' and selected_color != blank and media_alt_key contains selected_color_key
        if primary_media == nil or media.id != primary_media.id
          if media_alt contains 'model' or media_alt contains 'man' or media_alt contains 'men' or media_alt contains 'worn'
            assign secondary_image = media.preview_image
            break
          endif
        endif
      endif
    endfor

    if secondary_image == nil
      for media in card_product.media
        assign media_alt = media.alt | downcase
        assign media_alt_key = media_alt | replace: ' ', '_'
        if media.media_type == 'image' and selected_color != blank and media_alt_key contains selected_color_key
          if primary_media == nil or media.id != primary_media.id
            assign secondary_image = media.preview_image
            break
          endif
        endif
      endfor
    endif

    if secondary_image == nil and color_option != nil
      assign image_position = 0
      assign model_position = selected_color_position | plus: color_option.values.size
      for media in card_product.media
        if media.media_type == 'image'
          assign image_position = image_position | plus: 1
        endif
        if media.media_type == 'image' and image_position == model_position
          assign secondary_image = media.preview_image
          break
        endif
      endfor
    endif
  endif

  assign selected_asset_position = selected_color_position
  if selected_asset_position == 0
    assign selected_asset_position = 1
  endif
  assign is_on_sale = false
  if selected_variant.compare_at_price > selected_variant.price
    assign is_on_sale = true
  endif
%}

{% if card_product != blank and selected_variant != blank %}
  <article
    class="domaine-scope w-full max-w-[620px] bg-white"
    data-domaine-product-card
  >
    <div class="grid grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] items-end gap-6">
      <div>
        <div class="rounded-[10px] border border-[#e8e8e8] bg-white p-4 transition duration-300 hover:border-zinc-300">
        <div class="relative aspect-[275/301] overflow-hidden bg-white">
          <span
            class="absolute left-0 top-0 z-10 inline-flex h-[23px] min-w-[72px] items-center justify-center rounded-full border border-[#ff0000] bg-white px-3 text-[10px] font-medium leading-none tracking-normal text-[#ff0000]"
            data-domaine-sale-badge
            {% unless is_on_sale %}
              hidden
            {% endunless %}
          >
            On Sale!
          </span>

          <img
            class="h-full w-full object-contain p-1 transition duration-300"
            data-domaine-primary-image
            {% if primary_image %}
              src="{{ primary_image | image_url: width: 700 }}"
              srcset="{{ primary_image | image_url: width: 350 }} 350w, {{ primary_image | image_url: width: 700 }} 700w, {{ primary_image | image_url: width: 1000 }} 1000w"
            {% else %}
              hidden
            {% endif %}
            sizes="170px"
            alt="{{ selected_color | default: card_product.title | escape }} {{ card_product.title | escape }} flat shirt"
            width="700"
            height="875"
            loading="lazy"
          >
        </div>
        </div>

        {% if color_option != nil and color_option.values.size > 1 %}
          <div class="mt-4 flex flex-wrap gap-2" role="group" aria-label="Choose color">
            {% for color_value in color_option.values %}
              {% liquid
                assign color_value_downcase = color_value | downcase
                assign color_value_key = color_value_downcase | replace: ' ', '_'
                assign swatch_color_css = '#d4d4d8'
                case color_value_downcase
                  when 'blue'
                    assign swatch_color_css = '#0077c8'
                  when 'green'
                    assign swatch_color_css = '#6f9849'
                  when 'navy'
                    assign swatch_color_css = '#111849'
                  when 'orange'
                    assign swatch_color_css = '#ff5b13'
                  when 'pink'
                    assign swatch_color_css = '#ffc1e6'
                  when 'yellow'
                    assign swatch_color_css = '#f2d45f'
                endcase

                assign swatch_variant = nil
                for variant in card_product.variants
                  assign variant_color = variant.options[color_option_index] | downcase
                  if variant_color == color_value_downcase
                    assign swatch_variant = variant
                    if variant.available
                      break
                    endif
                  endif
                endfor

                assign swatch_primary_media = swatch_variant.featured_media
                assign swatch_primary_image = swatch_primary_media.preview_image
                assign swatch_secondary_image = nil
                assign swatch_color_position = forloop.index

                if swatch_primary_image == nil
                  for media in card_product.media
                    assign swatch_media_alt = media.alt | downcase
                    assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                      unless swatch_media_alt contains 'model' or swatch_media_alt contains 'man' or swatch_media_alt contains 'men' or swatch_media_alt contains 'worn'
                        assign swatch_primary_media = media
                        assign swatch_primary_image = media.preview_image
                        break
                      endunless
                    endif
                  endfor
                endif

                if swatch_primary_image == nil
                  for media in card_product.media
                    assign swatch_media_alt = media.alt | downcase
                    assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                      assign swatch_primary_media = media
                      assign swatch_primary_image = media.preview_image
                      break
                    endif
                  endfor
                endif

                for media in card_product.media
                  assign swatch_media_alt = media.alt | downcase
                  assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                  if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                    if swatch_primary_media == nil or media.id != swatch_primary_media.id
                      if swatch_media_alt contains 'model' or swatch_media_alt contains 'man' or swatch_media_alt contains 'men' or swatch_media_alt contains 'worn'
                        assign swatch_secondary_image = media.preview_image
                        break
                      endif
                    endif
                  endif
                endfor

                if swatch_secondary_image == nil
                  for media in card_product.media
                    assign swatch_media_alt = media.alt | downcase
                    assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                      if swatch_primary_media == nil or media.id != swatch_primary_media.id
                        assign swatch_secondary_image = media.preview_image
                        break
                      endif
                    endif
                  endfor
                endif

                if swatch_secondary_image == nil
                  assign swatch_image_position = 0
                  assign swatch_model_position = swatch_color_position | plus: color_option.values.size
                  for media in card_product.media
                    if media.media_type == 'image'
                      assign swatch_image_position = swatch_image_position | plus: 1
                    endif
                    if media.media_type == 'image' and swatch_image_position == swatch_model_position
                      assign swatch_secondary_image = media.preview_image
                      break
                    endif
                  endfor
                endif

                assign swatch_on_sale = false
                if swatch_variant.compare_at_price > swatch_variant.price
                  assign swatch_on_sale = true
                endif
                assign is_active = false
                if swatch_color_position == selected_asset_position
                  assign is_active = true
                endif
              %}

              <button
                type="button"
                class="h-4 w-4 rounded-full border border-transparent transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2 {% if is_active %}ring-2 ring-[#0a4874] ring-offset-2{% endif %}"
                style="background-color: {{ swatch_color_css | escape }};"
                aria-label="Select {{ color_value | escape }}"
                aria-pressed="{% if is_active %}true{% else %}false{% endif %}"
                title="{{ color_value | escape }}"
                data-domaine-swatch
                data-variant-id="{{ swatch_variant.id }}"
                data-price="{{ swatch_variant.price | money | escape }}"
                data-compare-price="{{ swatch_variant.compare_at_price | money | escape }}"
                data-on-sale="{% if swatch_on_sale %}true{% else %}false{% endif %}"
                {% if swatch_primary_image %}
                  data-primary-src="{{ swatch_primary_image | image_url: width: 700 }}"
                  data-primary-srcset="{{ swatch_primary_image | image_url: width: 350 }} 350w, {{ swatch_primary_image | image_url: width: 700 }} 700w, {{ swatch_primary_image | image_url: width: 1000 }} 1000w"
                {% endif %}
                {% if swatch_secondary_image %}
                  data-secondary-src="{{ swatch_secondary_image | image_url: width: 700 }}"
                  data-secondary-srcset="{{ swatch_secondary_image | image_url: width: 350 }} 350w, {{ swatch_secondary_image | image_url: width: 700 }} 700w, {{ swatch_secondary_image | image_url: width: 1000 }} 1000w"
                {% endif %}
                data-image-alt="{{ color_value | escape }} {{ card_product.title | escape }}"
                data-primary-alt="{{ color_value | escape }} {{ card_product.title | escape }} flat shirt"
                data-secondary-alt="{{ color_value | escape }} {{ card_product.title | escape }} worn by model"
              >
                <span class="sr-only">{{ color_value | escape }}</span>
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div>
        <img
          class="h-full max-h-[560px] w-full object-contain transition duration-300"
          data-domaine-secondary-image
          {% if secondary_image %}
              src="{{ secondary_image | image_url: width: 700 }}"
              srcset="{{ secondary_image | image_url: width: 350 }} 350w, {{ secondary_image | image_url: width: 700 }} 700w, {{ secondary_image | image_url: width: 1000 }} 1000w"
          {% else %}
            hidden
          {% endif %}
          sizes="210px"
          alt="{{ selected_color | default: card_product.title | escape }} {{ card_product.title | escape }} worn by model"
          width="620"
          height="775"
          loading="lazy"
        >
      </div>
    </div>

    <div class="grid gap-3 pt-6">
      <div class="grid gap-1.5">
        {% if card_product.vendor != blank %}
          <p class="text-sm font-medium leading-tight tracking-normal text-[#0a4874]">
            {{ card_product.vendor | escape }}
          </p>
        {% endif %}

        <h3 class="text-base font-medium leading-snug tracking-normal text-[#111111]">
          <a class="underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2" href="{{ card_product.url }}">
            {{ card_product.title | escape }}
          </a>
        </h3>
      </div>

      <div class="flex flex-wrap items-baseline gap-2">
        <s
          class="text-sm font-medium leading-none text-[#111111] decoration-[#111111]"
          data-domaine-compare-price
          {% unless is_on_sale %}
            hidden
          {% endunless %}
        >
          {{ selected_variant.compare_at_price | money }}
        </s>
        <span class="text-base font-medium leading-none {% if is_on_sale %}text-[#ff0000]{% else %}text-[#111111]{% endif %}" data-domaine-price>
          {{ selected_variant.price | money }}
        </span>
      </div>
    </div>
  </article>
{% endif %}
