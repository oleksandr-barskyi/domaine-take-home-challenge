{% comment %}
  Reusable Domaine product card.
  Accepts:
  - product: Shopify product object
  - media_link: optional boolean. If true, image area links to the product page.
{% endcomment %}

{% liquid
  assign card_product = product
  assign card_media_links_to_product = media_link | default: false
  assign selected_variant = card_product.selected_or_first_available_variant
  assign color_option_index = nil
  assign color_option = nil

  for option in card_product.options_with_values
    assign option_name = option.name | downcase
    if option_name contains 'color' or option_name contains 'colour'
      assign color_option_index = forloop.index0
      assign color_option = option
      break
    endif
  endfor

  assign selected_color = ''
  assign selected_color_position = 0

  if color_option_index != nil
    assign selected_color = selected_variant.options[color_option_index] | downcase
    assign selected_color_key = selected_color | replace: ' ', '_'
    for color_value in color_option.values
      assign color_value_downcase = color_value | downcase
      if color_value_downcase == selected_color
        assign selected_color_position = forloop.index
        break
      endif
    endfor
  endif

  assign primary_media = selected_variant.featured_media
  assign primary_image = primary_media.preview_image
  assign secondary_image = nil

  if primary_image == nil and selected_color != blank
    for media in card_product.media
      assign media_alt = media.alt | downcase
      assign media_alt_key = media_alt | replace: ' ', '_'
      if media.media_type == 'image' and media_alt_key contains selected_color_key
        unless media_alt contains 'model' or media_alt contains 'man' or media_alt contains 'men' or media_alt contains 'worn'
          assign primary_media = media
          assign primary_image = media.preview_image
          break
        endunless
      endif
    endfor
  endif

  if primary_image == nil and selected_color != blank
    for media in card_product.media
      assign media_alt = media.alt | downcase
      assign media_alt_key = media_alt | replace: ' ', '_'
      if media.media_type == 'image' and media_alt_key contains selected_color_key
        assign primary_media = media
        assign primary_image = media.preview_image
        break
      endif
    endfor
  endif

  if primary_image == nil
    assign primary_image = card_product.featured_image
  endif

  if card_product.media.size > 1
    for media in card_product.media
      assign media_alt = media.alt | downcase
      assign media_alt_key = media_alt | replace: ' ', '_'
      if media.media_type == 'image' and selected_color != blank and media_alt_key contains selected_color_key
        if primary_media == nil or media.id != primary_media.id
          if media_alt contains 'model' or media_alt contains 'man' or media_alt contains 'men' or media_alt contains 'worn'
            assign secondary_image = media.preview_image
            break
          endif
        endif
      endif
    endfor

    if secondary_image == nil
      for media in card_product.media
        assign media_alt = media.alt | downcase
        assign media_alt_key = media_alt | replace: ' ', '_'
        if media.media_type == 'image' and selected_color != blank and media_alt_key contains selected_color_key
          if primary_media == nil or media.id != primary_media.id
            assign secondary_image = media.preview_image
            break
          endif
        endif
      endfor
    endif

    if secondary_image == nil and color_option != nil
      assign image_position = 0
      assign model_position = selected_color_position | plus: color_option.values.size
      for media in card_product.media
        if media.media_type == 'image'
          assign image_position = image_position | plus: 1
        endif
        if media.media_type == 'image' and image_position == model_position
          assign secondary_image = media.preview_image
          break
        endif
      endfor
    endif
  endif

  assign selected_asset_position = selected_color_position
  if selected_asset_position == 0
    assign selected_asset_position = 1
  endif
  assign is_on_sale = false
  if selected_variant.compare_at_price > selected_variant.price
    assign is_on_sale = true
  endif
%}

{% if card_product != blank and selected_variant != blank %}
  <article
    class="domaine-scope flex w-full max-w-[344px] flex-col bg-white"
    data-domaine-product-card
    data-has-secondary="{% if secondary_image %}true{% else %}false{% endif %}"
    data-image-view="primary"
  >
    <div class="domaine-card-media block w-full">
      <div class="block w-full">
        <div class="domaine-card-frame rounded-[16px] border border-[#e8e8e8] bg-white p-4 transition duration-300">
        {% if card_media_links_to_product %}
          <a
            class="relative block aspect-[275/301] w-full overflow-hidden bg-white p-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2"
            href="{{ card_product.url }}"
            aria-label="View details for {{ card_product.title | escape }}"
          >
        {% else %}
          <button
            type="button"
            class="relative block aspect-[275/301] w-full overflow-hidden bg-white p-0"
            data-domaine-media-toggle
            aria-label="Show alternate image for {{ card_product.title | escape }}"
            aria-pressed="false"
            {% unless secondary_image %}
              disabled
            {% endunless %}
          >
        {% endif %}
          <span
            class="absolute left-3 top-3 z-10 inline-flex h-[34px] min-w-[94px] items-center justify-center rounded-full border border-[#ff0000] bg-white px-4 text-[15px] font-medium leading-[18px] tracking-normal text-[#ff0000]"
            data-domaine-sale-badge
            {% unless is_on_sale %}
              hidden
            {% endunless %}
          >
            On Sale!
          </span>

          <img
            class="h-full w-full object-contain p-0 transition-opacity duration-300"
            data-domaine-primary-image
            {% if primary_image %}
              src="{{ primary_image | image_url: width: 700 }}"
              srcset="{{ primary_image | image_url: width: 350 }} 350w, {{ primary_image | image_url: width: 700 }} 700w, {{ primary_image | image_url: width: 1000 }} 1000w"
            {% else %}
              hidden
            {% endif %}
            sizes="170px"
            alt="{{ selected_color | default: card_product.title | escape }} {{ card_product.title | escape }} flat shirt"
            width="700"
            height="875"
            loading="lazy"
          >

          <img
            class="absolute inset-0 h-full w-full object-contain p-0 opacity-0 transition-opacity duration-300"
            data-domaine-secondary-image
            {% if secondary_image %}
              src="{{ secondary_image | image_url: width: 700 }}"
              srcset="{{ secondary_image | image_url: width: 350 }} 350w, {{ secondary_image | image_url: width: 700 }} 700w, {{ secondary_image | image_url: width: 1000 }} 1000w"
            {% else %}
              hidden
            {% endif %}
            sizes="170px"
            alt="{{ selected_color | default: card_product.title | escape }} {{ card_product.title | escape }} worn by model"
            width="700"
            height="875"
            loading="lazy"
          >
        {% if card_media_links_to_product %}
          </a>
        {% else %}
          </button>
        {% endif %}
        </div>

        {% if color_option != nil and color_option.values.size > 1 %}
          <div class="mt-5 flex flex-wrap gap-2.5" role="group" aria-label="Choose color">
            {% for color_value in color_option.values %}
              {% liquid
                assign color_value_name = color_value.name
                if color_value_name == blank
                  assign color_value_name = color_value
                endif
                assign color_value_downcase = color_value_name | downcase
                assign color_value_key = color_value_downcase | replace: ' ', '_'
                assign swatch = color_value.swatch
                assign swatch_color = swatch.color
                assign swatch_color_css = '#d4d4d8'

                if swatch_color != blank
                  assign swatch_color_css = swatch_color
                else
                  case color_value_downcase
                    when 'blue'
                      assign swatch_color_css = '#00639c'
                    when 'green'
                      assign swatch_color_css = '#006600'
                    when 'navy'
                      assign swatch_color_css = '#19264b'
                    when 'orange'
                      assign swatch_color_css = '#ff6633'
                    when 'pink'
                      assign swatch_color_css = '#ffccff'
                    when 'yellow'
                      assign swatch_color_css = '#fce78d'
                    when 'graphite'
                      assign swatch_color_css = '#2f3437'
                    when 'ivory'
                      assign swatch_color_css = '#f4efe6'
                    when 'clay'
                      assign swatch_color_css = '#b86f52'
                    when 'moss'
                      assign swatch_color_css = '#61705a'
                    when 'mist'
                      assign swatch_color_css = '#b9c6c9'
                    when 'cocoa'
                      assign swatch_color_css = '#6f5142'
                  endcase
                endif

                assign swatch_variant = nil
                for variant in card_product.variants
                  assign variant_color = variant.options[color_option_index] | downcase
                  if variant_color == color_value_downcase
                    assign swatch_variant = variant
                    if variant.available
                      break
                    endif
                  endif
                endfor

                assign swatch_primary_media = swatch_variant.featured_media
                assign swatch_primary_image = swatch_primary_media.preview_image
                assign swatch_secondary_image = nil
                assign swatch_color_position = forloop.index

                if swatch_primary_image == nil
                  for media in card_product.media
                    assign swatch_media_alt = media.alt | downcase
                    assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                      unless swatch_media_alt contains 'model' or swatch_media_alt contains 'man' or swatch_media_alt contains 'men' or swatch_media_alt contains 'worn'
                        assign swatch_primary_media = media
                        assign swatch_primary_image = media.preview_image
                        break
                      endunless
                    endif
                  endfor
                endif

                if swatch_primary_image == nil
                  for media in card_product.media
                    assign swatch_media_alt = media.alt | downcase
                    assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                      assign swatch_primary_media = media
                      assign swatch_primary_image = media.preview_image
                      break
                    endif
                  endfor
                endif

                if swatch_primary_image == nil
                  assign swatch_primary_image = card_product.featured_image
                endif

                for media in card_product.media
                  assign swatch_media_alt = media.alt | downcase
                  assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                  if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                    if swatch_primary_media == nil or media.id != swatch_primary_media.id
                      if swatch_media_alt contains 'model' or swatch_media_alt contains 'man' or swatch_media_alt contains 'men' or swatch_media_alt contains 'worn'
                        assign swatch_secondary_image = media.preview_image
                        break
                      endif
                    endif
                  endif
                endfor

                if swatch_secondary_image == nil
                  for media in card_product.media
                    assign swatch_media_alt = media.alt | downcase
                    assign swatch_media_alt_key = swatch_media_alt | replace: ' ', '_'
                    if media.media_type == 'image' and swatch_media_alt_key contains color_value_key
                      if swatch_primary_media == nil or media.id != swatch_primary_media.id
                        assign swatch_secondary_image = media.preview_image
                        break
                      endif
                    endif
                  endfor
                endif

                if swatch_secondary_image == nil
                  assign swatch_image_position = 0
                  assign swatch_model_position = swatch_color_position | plus: color_option.values.size
                  for media in card_product.media
                    if media.media_type == 'image'
                      assign swatch_image_position = swatch_image_position | plus: 1
                    endif
                    if media.media_type == 'image' and swatch_image_position == swatch_model_position
                      assign swatch_secondary_image = media.preview_image
                      break
                    endif
                  endfor
                endif

                assign swatch_on_sale = false
                if swatch_variant.compare_at_price > swatch_variant.price
                  assign swatch_on_sale = true
                endif
                assign is_active = false
                if swatch_color_position == selected_asset_position
                  assign is_active = true
                endif
              %}

              <button
                type="button"
                class="flex h-6 w-6 items-center justify-center rounded-full p-0 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2"
                aria-label="Select {{ color_value_name | escape }}"
                aria-pressed="{% if is_active %}true{% else %}false{% endif %}"
                title="{{ color_value_name | escape }}"
                data-domaine-swatch
                data-variant-id="{{ swatch_variant.id }}"
                data-color-value="{{ color_value_downcase | escape }}"
                data-price="{{ swatch_variant.price | money | escape }}"
                data-compare-price="{{ swatch_variant.compare_at_price | money | escape }}"
                data-on-sale="{% if swatch_on_sale %}true{% else %}false{% endif %}"
                {% if swatch_primary_image %}
                  data-primary-src="{{ swatch_primary_image | image_url: width: 700 }}"
                  data-primary-srcset="{{ swatch_primary_image | image_url: width: 350 }} 350w, {{ swatch_primary_image | image_url: width: 700 }} 700w, {{ swatch_primary_image | image_url: width: 1000 }} 1000w"
                {% endif %}
                {% if swatch_secondary_image %}
                  data-secondary-src="{{ swatch_secondary_image | image_url: width: 700 }}"
                  data-secondary-srcset="{{ swatch_secondary_image | image_url: width: 350 }} 350w, {{ swatch_secondary_image | image_url: width: 700 }} 700w, {{ swatch_secondary_image | image_url: width: 1000 }} 1000w"
                {% endif %}
                data-image-alt="{{ color_value_name | escape }} {{ card_product.title | escape }}"
                data-primary-alt="{{ color_value_name | escape }} {{ card_product.title | escape }} flat shirt"
                data-secondary-alt="{{ color_value_name | escape }} {{ card_product.title | escape }} worn by model"
              >
                <span
                  class="flex h-6 w-6 items-center justify-center rounded-full border"
                  style="border-color: {% if is_active %}var(--domaine-card-active-color, #0a4874){% else %}transparent{% endif %};"
                  data-domaine-swatch-ring
                  aria-hidden="true"
                >
                  <span
                    class="block rounded-full bg-cover bg-center"
                    style="width: 20px; height: 20px; background-color: {{ swatch_color_css | escape }};"
                  ></span>
                </span>
                <span class="sr-only">{{ color_value_name | escape }}</span>
              </button>
            {% endfor %}
          </div>
        {% elsif card_product.variants.size > 1 %}
          <label class="mt-5 block">
            <span class="sr-only">Choose variant</span>
            <select
              class="h-[42px] w-full rounded-lg border border-zinc-300 bg-white px-3 text-sm text-[#111111] outline-none transition focus:border-[#0a4874] focus:ring-2 focus:ring-[#0a4874]"
              data-domaine-variant-select
            >
              {% for variant in card_product.variants %}
                {% liquid
                  assign variant_on_sale = false
                  if variant.compare_at_price > variant.price
                    assign variant_on_sale = true
                  endif

                  assign variant_primary_image = variant.featured_media.preview_image
                  if variant_primary_image == nil
                    assign variant_primary_image = card_product.featured_image
                  endif
                %}

                <option
                  value="{{ variant.id }}"
                  data-price="{{ variant.price | money | escape }}"
                  data-compare-price="{{ variant.compare_at_price | money | escape }}"
                  data-on-sale="{% if variant_on_sale %}true{% else %}false{% endif %}"
                  data-available="{% if variant.available %}true{% else %}false{% endif %}"
                  {% if variant_primary_image %}
                    data-primary-src="{{ variant_primary_image | image_url: width: 700 }}"
                    data-primary-srcset="{{ variant_primary_image | image_url: width: 350 }} 350w, {{ variant_primary_image | image_url: width: 700 }} 700w, {{ variant_primary_image | image_url: width: 1000 }} 1000w"
                  {% endif %}
                  data-primary-alt="{{ variant.title | escape }} {{ card_product.title | escape }}"
                  {% if variant.id == selected_variant.id %}
                    selected
                  {% endif %}
                >
                  {{ variant.title | escape }}{% unless variant.available %} - Sold out{% endunless %}
                </option>
              {% endfor %}
            </select>
          </label>
        {% endif %}
      </div>
    </div>

    <div class="domaine-card-info grid w-full gap-2 pt-5">
      <div class="grid gap-1.5">
        {% if card_product.vendor != blank %}
          <p class="text-sm font-normal leading-4 tracking-normal text-[#111111]" data-domaine-card-vendor>
            {{ card_product.vendor | escape }}
          </p>
        {% endif %}

        <h3 class="text-base font-semibold leading-[18px] tracking-normal text-[#0a4874]" data-domaine-card-title>
          <a class="underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2" href="{{ card_product.url }}">
            {{ card_product.title | escape }}
          </a>
        </h3>
      </div>

      <div class="flex flex-wrap items-baseline gap-2">
        <s
          class="text-sm font-normal leading-4 text-[#111111] decoration-[#111111]"
          data-domaine-compare-price
          {% unless is_on_sale %}
            hidden
          {% endunless %}
        >
          {{ selected_variant.compare_at_price | money }}
        </s>
        <span class="text-sm font-normal leading-4 {% if is_on_sale %}text-[#ff0000]{% else %}text-[#111111]{% endif %}" data-domaine-price>
          {{ selected_variant.price | money }}
        </span>
      </div>

      <button id='add-to-cart' data-variant-id="{{ selected_variant.id }}" class="inline-flex w-fit items-center justify-center rounded-full border border-[#0a4874] px-5 py-2 text-sm font-medium leading-none tracking-normal text-[#0a4874] transition hover:bg-[#0a4874] hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#0a4874] focus-visible:ring-offset-2">
        Add to cart
      </button>

    </div>
  </article>
{% endif %}
